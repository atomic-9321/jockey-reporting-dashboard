# Meta Marketing API
META_ACCESS_TOKEN=your_meta_access_token
META_EU_ACCOUNT_ID=act_XXXXXXXXXX
META_UK_ACCOUNT_ID=act_XXXXXXXXXX
META_TOKEN_CREATED_AT=2026-04-06

# Google Sheets
GOOGLE_SHEETS_EU_ID=your_eu_spreadsheet_id
GOOGLE_SHEETS_UK_ID=your_uk_spreadsheet_id

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=vercel_blob_XXXXXXXXXX

# Auth (V1: simple credentials)
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000
AUTH_USERS=admin@example.com:changeme,viewer@example.com:changeme

# Notifications (optional - for token expiry alerts)
NOTIFICATION_SLACK_WEBHOOK=https://hooks.slack.com/services/XXX/XXX/XXX
# Or use SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your_app_password
# ALERT_EMAIL_TO=alerts@yourdomain.com

# Data refresh config
REFRESH_INTERVAL_HOURS=6
